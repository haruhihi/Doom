<!-- 首页 -->
<navigation-bar title="" back="{{false}}" color="#c9a96e" background="transparent"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="index-page">

    <!-- 标题区域 -->
    <view class="header">
      <view class="taiji">
        <image class="taiji-icon" src="../../images/app-icon.png" mode="aspectFit"></image>
      </view>
      <text class="app-title">易简研习</text>
      <text class="app-subtitle">以简研易，可通天下</text>
    </view>

    <!-- 体验按钮 -->
    <view class="divine-area">
      <view class="divine-btn-wrapper" bindtap="onStartDivine">
        <view class="divine-btn-glow"></view>
        <view class="divine-btn">
          <text class="divine-btn-text">体验</text>
        </view>
      </view>
      <text class="divine-btn-hint">点击开始铜钱体验</text>
    </view>

    <!-- 最近记录 -->
    <view class="recent-section" wx:if="{{lastRecord}}">
      <text class="section-label">上次体验</text>
      <view class="recent-card" bindtap="onViewLastRecord">
        <view class="recent-left">
          <hexagram-figure lines="{{lastRecord.hexagram.lines}}" size="small"></hexagram-figure>
        </view>
        <view class="recent-right">
          <view class="recent-header">
            <text class="recent-name">{{lastRecord.hexagram.name}}卦</text>
            <text class="recent-time">{{lastRecord.timeStr}}</text>
          </view>
          <text class="recent-judgment">{{lastRecord.hexagram.judgment}}</text>
          <text class="recent-interp">{{lastRecord.hexagram.interpretation}}</text>
        </view>
      </view>
    </view>

    <!-- 测试按钮（仅开发/体验环境可见） -->
    <view class="test-area" wx:if="{{isDev}}">
      <view class="test-btn" bindtap="onTestDivine">
        <text>测试：选择变爻场景</text>
      </view>
    </view>

    <!-- 底部装饰 -->
    <view class="footer-deco">
      <text class="footer-text">{{footerQuote}} ——{{footerSource}}</text>
    </view>

  </view>
</scroll-view>

<!-- ========== 情境选择 底部Sheet ========== -->
<view class="sheet-overlay {{showSceneSheet ? 'sheet-overlay--show' : ''}}" bindtap="onCloseSceneSheet">
  <view class="sheet-container {{showSceneSheet ? 'sheet-container--show' : ''}}" catchtap="onStopPropagation">
    <view class="sheet-handle-bar">
      <view class="sheet-handle"></view>
    </view>
    <view class="sheet-header">
      <text class="sheet-title">选择主题</text>
      <view class="sheet-close" bindtap="onCloseSceneSheet">
        <text class="sheet-close-icon">×</text>
      </view>
    </view>
    <view class="sheet-body">
      <text class="sheet-desc">选择一个主题，获取更贴切的解读</text>
      <view class="scenario-grid">
        <view
          wx:for="{{scenarioMetas}}"
          wx:key="key"
          class="scenario-tag {{selectedScene === item.key ? 'scenario-tag--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSelectScene"
        >
          <text class="scenario-tag-emoji">{{item.emoji}}</text>
          <text class="scenario-tag-label">{{item.label}}</text>
        </view>
      </view>
      <button class="sheet-confirm-btn" bindtap="onConfirmScene">开始体验</button>
    </view>
  </view>
</view>

<!-- ========== 测试场景选择 Sheet ========== -->
<view class="sheet-overlay {{showTestSheet ? 'sheet-overlay--show' : ''}}" bindtap="onCloseTestSheet">
  <view class="sheet-container {{showTestSheet ? 'sheet-container--show' : ''}}" catchtap="onStopPropagation">
    <view class="sheet-handle-bar">
      <view class="sheet-handle"></view>
    </view>
    <view class="sheet-header">
      <text class="sheet-title">测试场景</text>
      <view class="sheet-close" bindtap="onCloseTestSheet">
        <text class="sheet-close-icon">×</text>
      </view>
    </view>
    <view class="sheet-body">
      <view class="test-case-list">
        <view
          wx:for="{{testCases}}"
          wx:key="desc"
          class="test-case-item"
          data-idx="{{index}}"
          bindtap="onSelectTestCase"
        >
          <text class="test-case-desc">{{item.desc}}</text>
          <text class="test-case-scene">{{item.scene}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
