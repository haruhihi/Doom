<!-- 卦象结果页 -->
<navigation-bar title="爻辞解读" back="{{true}}" color="#c9a96e" background="#1a1a2e" delta="{{0}}" bind:back="onBack"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="result-page" wx:if="{{hexagram}}">

    <!-- 卦象展示区 -->
    <view class="hex-display">
      <view class="hex-main">
        <hexagram-figure lines="{{hexagram.lines}}" changingLines="{{changingLines}}" size="large"></hexagram-figure>
        <text class="hex-name">{{hexagram.symbol}} {{hexagram.name}}</text>
        <text class="hex-trigrams">{{hexagram.upperTrigram}} 上 · {{hexagram.lowerTrigram}} 下</text>
      </view>

      <!-- 变卦 -->
      <block wx:if="{{changedHexagram}}">
        <view class="hex-arrow">
          <text class="hex-arrow-text">变</text>
        </view>
        <view class="hex-changed">
          <hexagram-figure lines="{{changedHexagram.lines}}" size="large"></hexagram-figure>
          <text class="hex-name">{{changedHexagram.symbol}} {{changedHexagram.name}}</text>
          <text class="hex-trigrams">{{changedHexagram.upperTrigram}} 上 · {{changedHexagram.lowerTrigram}} 下</text>
        </view>
      </block>
    </view>

    <!-- ========== 情境指引 (Premium) ========== -->
    <view class="scenario-section">
      <view class="section-header">
        <text class="section-title">情境指引</text>
      </view>
      <view class="scenario-grid">
        <view
          wx:for="{{scenarioMetas}}"
          wx:key="key"
          class="scenario-tag {{activeScene === item.key ? 'scenario-tag--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSelectScene"
        >
          <text class="scenario-tag-emoji">{{item.emoji}}</text>
          <text class="scenario-tag-label">{{item.label}}</text>
        </view>
      </view>
      <view class="scenario-content" wx:if="{{scenarioContent}}">
        <view class="scenario-change-note" wx:if="{{changedHexagram}}">
          <text class="scenario-change-note-text">以下启示基于本卦「{{hexagram.name}}」。变爻的具体启示请参阅下方变爻解读部分。</text>
        </view>
        <text class="scenario-text">{{scenarioContent}}</text>
      </view>
      <view class="scenario-disclaimer" wx:if="{{scenarioContent}}">
        <text class="scenario-disclaimer-text">以上内容基于《易经》古籍的文化解读，仅供学习参考。</text>
      </view>
    </view>

    <!-- ========== 卦辞与解读（合并区块） ========== -->
    <view class="section judgment-section">
      <view class="section-header section-header--with-action">
        <text class="section-title">卦辞与解读</text>
        <view class="section-action" bindtap="onShowLineSheet">
          <text class="section-action-text">查看爻辞</text>
          <text class="section-action-arrow">›</text>
        </view>
      </view>
      <view class="section-body judgment-body">
        <!-- 本卦 -->
        <view class="judgment-item">
          <text class="judgment-label">{{hexagram.name}} · 卦辞</text>
          <text class="judgment-classical">{{hexagram.judgment}}</text>
          <text class="judgment-translation" wx:if="{{hexagram.judgmentTranslation}}">{{hexagram.judgmentTranslation}}</text>
          <text class="judgment-interp">{{hexagram.interpretation}}</text>
        </view>

        <!-- 变卦（若有） -->
        <block wx:if="{{changedHexagram}}">
          <view class="judgment-divider">
            <view class="judgment-divider-line"></view>
            <text class="judgment-divider-text">变卦</text>
            <view class="judgment-divider-line"></view>
          </view>
          <view class="judgment-item judgment-item--changed">
            <text class="judgment-label judgment-label--changed">{{changedHexagram.name}} · 变卦卦辞</text>
            <text class="judgment-classical">{{changedHexagram.judgment}}</text>
            <text class="judgment-translation" wx:if="{{changedHexagram.judgmentTranslation}}">{{changedHexagram.judgmentTranslation}}</text>
            <text class="judgment-interp">{{changedHexagram.interpretation}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- ========== 变爻解读 ========== -->
    <view class="section changing-section" wx:if="{{changingLineDetails.length > 0}}">
      <view class="section-header section-header--with-action">
        <text class="section-title">变爻解读</text>
        <view class="section-action" bindtap="onShowChangeTipSheet">
          <text class="section-action-text">了解变卦</text>
          <text class="section-action-arrow">›</text>
        </view>
      </view>
      <view class="section-body changing-body">
        <!-- 朱熹规则栏 -->
        <view class="zhuxi-bar" wx:if="{{currentZhuxiRule}}">
          <view class="zhuxi-bar-content">
            <view class="zhuxi-bar-row">
              <text class="zhuxi-bar-count">{{changingLines.length}} 条变爻</text>
              <text class="zhuxi-bar-sep">·</text>
              <text class="zhuxi-bar-focus">{{currentZhuxiRule.focus}}</text>
            </view>
            <text class="zhuxi-bar-reason">{{currentZhuxiRule.reason}}</text>
          </view>
          <view class="zhuxi-tip-icon" bindtap="onShowZhuxiModal">
            <text class="zhuxi-tip-icon-text">?</text>
          </view>
        </view>

        <!-- 变爻列表 -->
        <view class="changing-list">
          <view class="changing-card" wx:for="{{changingLineDetails}}" wx:key="position">
            <!-- 本卦爻辞 -->
            <view class="changing-card-side">
              <view class="changing-card-tag">
                <text class="changing-card-tag-hex">{{hexagram.name}}</text>
                <text class="changing-card-tag-pos">{{item.positionName}}</text>
              </view>
              <text class="changing-card-text">{{item.originalText}}</text>
              <text class="changing-card-interp" wx:if="{{item.originalInterp}}">{{item.originalInterp}}</text>
            </view>
            <!-- 变化指示 -->
            <view class="changing-card-arrow">
              <text class="changing-card-arrow-icon">↓ 变 ↓</text>
            </view>
            <!-- 变卦爻辞 -->
            <view class="changing-card-side">
              <view class="changing-card-tag">
                <text class="changing-card-tag-hex changing-card-tag-hex--changed">{{changedHexagram.name}}</text>
                <text class="changing-card-tag-pos">{{item.positionName}}</text>
              </view>
              <text class="changing-card-text">{{item.changedText}}</text>
              <text class="changing-card-interp" wx:if="{{item.changedInterp}}">{{item.changedInterp}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="action-btn action-btn--save" bindtap="onSave">保存记录</button>
      <button class="action-btn action-btn--again" bindtap="onDivineAgain">重新体验</button>
    </view>

    <!-- 底部免责声明 -->
    <view class="page-disclaimer">
      <text class="page-disclaimer-text">本内容仅供传统文化学习参考，不构成任何现实决策依据。</text>
    </view>

  </view>
</scroll-view>

<!-- ========== 爻辞详情 底部Sheet ========== -->
<view class="sheet-overlay {{showLineSheet ? 'sheet-overlay--show' : ''}}" bindtap="onCloseLineSheet">
  <view class="sheet-container {{showLineSheet ? 'sheet-container--show' : ''}}" catchtap="onStopPropagation">
    <view class="sheet-handle-bar">
      <view class="sheet-handle"></view>
    </view>
    <view class="sheet-header">
      <text class="sheet-title">{{hexagram.name}} · 全部爻辞</text>
      <view class="sheet-close" bindtap="onCloseLineSheet">
        <text class="sheet-close-icon">×</text>
      </view>
    </view>
    <scroll-view class="sheet-scroll" scroll-y>
      <view class="sheet-content">
        <view class="line-detail-item {{item.isChanging ? 'line-detail-item--changing' : ''}}" wx:for="{{allLineTexts}}" wx:key="position">
          <view class="line-detail-header">
            <text class="line-detail-pos">{{item.positionName}}</text>
            <text wx:if="{{item.isChanging}}" class="line-detail-badge">变爻</text>
          </view>
          <text class="line-detail-classical">{{item.text}}</text>
          <text class="line-detail-interp" wx:if="{{item.interp}}">{{item.interp}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- ========== 了解变卦 底部Sheet ========== -->
<view class="sheet-overlay {{showChangeTipSheet ? 'sheet-overlay--show' : ''}}" bindtap="onCloseChangeTipSheet">
  <view class="sheet-container {{showChangeTipSheet ? 'sheet-container--show' : ''}}" catchtap="onStopPropagation">
    <view class="sheet-handle-bar">
      <view class="sheet-handle"></view>
    </view>
    <view class="sheet-header">
      <text class="sheet-title">了解变卦</text>
      <view class="sheet-close" bindtap="onCloseChangeTipSheet">
        <text class="sheet-close-icon">×</text>
      </view>
    </view>
    <view class="sheet-body">
      <view class="change-tip-section">
        <text class="change-tip-heading">什么是变爻？</text>
        <text class="change-tip-paragraph">在易经中，当某一爻的铜钱结果为三正（老阳·9）或三反（老阴·6）时，该爻为「变爻」，表示事物正处于转化之际。</text>
      </view>
      <view class="change-tip-section" wx:if="{{changedHexagram}}">
        <text class="change-tip-heading">本卦与变卦</text>
        <text class="change-tip-paragraph">本卦「{{hexagram.name}}」代表当前的处境与态势；变卦「{{changedHexagram.name}}」则揭示事态发展的方向与趋势。</text>
      </view>
      <view class="change-tip-section">
        <text class="change-tip-heading">如何解读？</text>
        <text class="change-tip-paragraph">变爻所在的爻辞，往往是本次体验最关键的启示所在。可参考上方的「朱熹断卦法」来确定重点关注哪些爻辞。</text>
      </view>
    </view>
  </view>
</view>

<!-- ========== 朱熹断卦法 模态 ========== -->
<view class="modal-overlay {{showZhuxiModal ? 'modal-overlay--show' : ''}}" bindtap="onCloseZhuxiModal">
  <view class="modal-container {{showZhuxiModal ? 'modal-container--show' : ''}}" catchtap="onStopPropagation">
    <view class="modal-header">
      <text class="modal-title">朱熹断卦法</text>
      <view class="modal-close" bindtap="onCloseZhuxiModal">
        <text class="modal-close-icon">×</text>
      </view>
    </view>
    <view class="modal-desc">
      <text class="modal-desc-text">根据变爻数量，决定重点参看哪部分爻辞：</text>
    </view>
    <view class="modal-body">
      <view class="zhuxi-table">
        <!-- 表头 -->
        <view class="zhuxi-table-row zhuxi-table-header">
          <text class="zhuxi-table-cell zhuxi-table-cell--count">变爻</text>
          <text class="zhuxi-table-cell zhuxi-table-cell--focus">看什么</text>
          <text class="zhuxi-table-cell zhuxi-table-cell--reason">为什么</text>
        </view>
        <!-- 数据行 -->
        <view class="zhuxi-table-row {{item.count === changingLines.length ? 'zhuxi-table-row--active' : ''}}"
              wx:for="{{zhuxiRules}}" wx:key="count">
          <text class="zhuxi-table-cell zhuxi-table-cell--count">{{item.count}}</text>
          <text class="zhuxi-table-cell zhuxi-table-cell--focus">{{item.focus}}</text>
          <text class="zhuxi-table-cell zhuxi-table-cell--reason">{{item.reason}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
