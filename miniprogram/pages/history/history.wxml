<!-- 历史记录页 -->
<navigation-bar title="历史记录" back="{{true}}" color="#c9a96e" background="#1a1a2e"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="history-page">

    <view wx:if="{{historyList.length === 0}}" class="empty">
      <text class="empty-icon">☯</text>
      <text class="empty-text">暂无体验记录</text>
      <text class="empty-hint">去首页体验吧</text>
    </view>

    <view wx:else>
      <!-- 清空按钮 -->
      <view class="clear-bar">
        <text class="record-count">共 {{historyList.length}} 条记录</text>
        <view class="clear-btn" bindtap="onClearAll" hover-class="tap-feedback">
          <text>清空</text>
        </view>
      </view>

      <!-- 记录列表 — 左滑出现删除 -->
      <view
        wx:for="{{historyList}}"
        wx:key="id"
        class="record-swipe"
      >
        <!-- 删除按钮（在卡片下方，滑动后露出） -->
        <view wx:if="{{activeSwipeIndex === index}}" class="record-delete" data-index="{{index}}" catchtap="onDeleteRecord" hover-class="tap-feedback">
          <text class="record-delete-text">删除</text>
        </view>
        <!-- 卡片主体 -->
        <view
          class="swipe-body {{activeSwipeIndex === index ? 'swipe-body--swiped' : ''}}"
          data-index="{{index}}"
          bindtouchstart="onRecordTouchStart"
          bindtouchmove="onRecordTouchMove"
          bindtouchend="onRecordTouchEnd"
        >
          <record-card record="{{item}}" />
        </view>
      </view>
    </view>

  </view>
</scroll-view>
