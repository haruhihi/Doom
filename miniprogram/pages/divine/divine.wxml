<!-- 铜钱体验页面 -->
<navigation-bar title="铜钱体验" back="{{true}}" color="#c9a96e" background="#1a1a2e"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="divine-page">

    <!-- 顶部提示 -->
    <view class="divine-header">
      <text class="divine-main-hint {{isComplete ? 'divine-main-hint--done' : ''}}">{{headerHint}}</text>
      <text class="divine-step" wx:if="{{!isComplete}}">第 {{currentThrow + 1}} / 6 次</text>
      <text class="divine-step" wx:if="{{isComplete}}">六次完成</text>
    </view>

    <!-- 铜钱区域 -->
    <view class="coins-area">
      <view class="coin {{isAnimating ? (isQuickMode ? 'coin--flipping-quick' : 'coin--flipping') : ''}} {{coinResults[0] !== undefined ? (coinResults[0] ? 'coin--front' : 'coin--back') : ''}}"
      >
        <view class="coin-face coin-front">
          <text class="coin-text">正</text>
          <view class="coin-hole"></view>
        </view>
        <view class="coin-face coin-back">
          <text class="coin-text coin-text--back">反</text>
          <view class="coin-pattern"></view>
        </view>
      </view>
      <view class="coin {{isAnimating ? (isQuickMode ? 'coin--flipping-quick coin--flipping-delay1' : 'coin--flipping coin--flipping-delay1') : ''}} {{coinResults[1] !== undefined ? (coinResults[1] ? 'coin--front' : 'coin--back') : ''}}"
      >
        <view class="coin-face coin-front">
          <text class="coin-text">正</text>
          <view class="coin-hole"></view>
        </view>
        <view class="coin-face coin-back">
          <text class="coin-text coin-text--back">反</text>
          <view class="coin-pattern"></view>
        </view>
      </view>
      <view class="coin {{isAnimating ? (isQuickMode ? 'coin--flipping-quick coin--flipping-delay2' : 'coin--flipping coin--flipping-delay2') : ''}} {{coinResults[2] !== undefined ? (coinResults[2] ? 'coin--front' : 'coin--back') : ''}}"
      >
        <view class="coin-face coin-front">
          <text class="coin-text">正</text>
          <view class="coin-hole"></view>
        </view>
        <view class="coin-face coin-back">
          <text class="coin-text coin-text--back">反</text>
          <view class="coin-pattern"></view>
        </view>
      </view>
    </view>

    <!-- 投掷按钮 -->
    <view class="throw-btn-area" wx:if="{{!isComplete}}">
      <button
        class="mode-btn mode-btn--primary"
        disabled="{{isAnimating || isQuickMode}}"
        bindtap="onThrowCoins"
      >{{currentThrow > 0 ? '继续' : '分次掷出'}}</button>
      <button
        class="mode-btn mode-btn--ghost"
        disabled="{{isAnimating || currentThrow > 0}}"
        bindtap="onQuickDivine"
      >一键完成</button>
    </view>
    <view class="throw-btn-area" wx:if="{{isComplete}}">
      <text class="done-label">已完成</text>
    </view>

    <!-- 已投掷结果 -->
    <view class="results-area {{isComplete ? 'results-area--complete' : ''}}" wx:if="{{throwResults.length > 0}}">
      <text class="results-title">掷出结果</text>
      <text class="results-hint results-hint--info">每条线代表一个「爻」，实线为阳爻，断线为阴爻</text>
      <text class="results-hint" wx:if="{{hasChangingLine}}">「变」表示该爻正在变化，详情请点击「查看解读」</text>
      <view class="results-list">
        <view
          wx:for="{{throwResults}}"
          wx:key="index"
          class="result-item"
        >
          <text class="result-index">{{item.label}}</text>
          <view class="result-line {{item.isYang ? 'result-line--yang' : 'result-line--yin'}} {{item.isChanging ? 'result-line--changing' : ''}}">
            <view class="result-line__bar"></view>
            <view wx:if="{{!item.isYang}}" class="result-line__gap"></view>
            <view class="result-line__bar"></view>
          </view>
          <view class="result-changing-slot">
            <text wx:if="{{item.isChanging}}" class="result-changing">变</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 查看结果按钮 -->
    <view class="view-result-area" wx:if="{{isComplete}}">
      <button class="view-result-btn" bindtap="onViewResult">查看解读</button>
    </view>

  </view>
</scroll-view>
